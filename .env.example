DEBUG=True
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost
DB_NAME=aonegt_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Local dev: console backend prints emails. For SMTP, set EMAIL_HOST_* and use smtp backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=webmaster@localhost
FRONTEND_RESET_URL=aonegt://reset-password

# Production (DEBUG=False): comma-separated origins, no spaces unless part of URL.
CORS_ALLOWED_ORIGINS=https://app.example.com

# Zoho OAuth access token (refresh periodically). Required when REGISTER_REQUIRE_ZOHO_CONTACT is true.
# Scopes: ZohoInventory.contacts.READ (inventory source) or ZohoCommerce.salesorders.READ (commerce_salesorders).
ZOHO_ACCESS_TOKEN=

ZOHO_INVENTORY_ORGANIZATION_ID=
ZOHO_API_BASE_HOST=https://www.zohoapis.com

REGISTER_REQUIRE_ZOHO_CONTACT=false
REGISTER_ZOHO_EMAIL_SOURCE=inventory
ZOHO_COMMERCE_ORGANIZATION_ID=

# false = server uses DEFAULT_SHIPPING_AMOUNT only (recommended). true = accept client shipping_amount (dev).
CHECKOUT_TRUST_CLIENT_SHIPPING=false
DEFAULT_SHIPPING_AMOUNT=0
