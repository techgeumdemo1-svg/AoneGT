DEBUG=True
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost
DB_NAME=aonegt_db
DB_USER=postgres
# Required for PostgreSQL unless the server uses trust auth for this user.
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Local dev: console backend prints emails. For SMTP, set EMAIL_HOST_* and use smtp backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=webmaster@localhost
FRONTEND_RESET_URL=aonegt://reset-password

# Production (DEBUG=False): comma-separated origins, no spaces unless part of URL.
CORS_ALLOWED_ORIGINS=https://app.example.com

# Zoho OAuth access token (refresh periodically). Required when REGISTER_REQUIRE_ZOHO_CONTACT is true.
# Scopes: ZohoInventory.contacts.READ (inventory), ZohoCommerce.salesorders.READ (Commerce orders),
#         ZohoCommerce.items.READ (Commerce products proxy under /api/catalog/zoho-commerce/products/).
ZOHO_ACCESS_TOKEN=

ZOHO_INVENTORY_ORGANIZATION_ID=
ZOHO_API_BASE_HOST=https://www.zohoapis.com

# Registration gate: require email to exist in Zoho before POST /api/auth/register/ succeeds.
# Zoho Commerce: set REGISTER_ZOHO_EMAIL_SOURCE to commerce_salesorders (or commerce / zoho_commerce).
# Commerce checks sales orders with this email (not “customer with zero orders”).
REGISTER_REQUIRE_ZOHO_CONTACT=false
REGISTER_ZOHO_EMAIL_SOURCE=inventory
ZOHO_COMMERCE_ORGANIZATION_ID=

# ZohoCommerceService: OAuth refresh + storefront (domain-name header). Optional if you only use ZOHO_ACCESS_TOKEN.
# ZOHO_ORG_ID defaults to ZOHO_COMMERCE_ORGANIZATION_ID when unset.
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
# ZOHO_COMMERCE_BASE_URL=https://commerce.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_STORE_DOMAIN=
# ZOHO_ORG_ID=

# Multi-store: per Store set zoho_org_id, zoho_store_domain, optional OAuth (client_id, etc.).
# Product APIs: ?store_id=<Store.pk>. Falls back to ZOHO_* env when store fields are empty.
# When store_id is omitted, ZOHO_STORE_DOMAIN and ZOHO_COMMERCE_ORGANIZATION_ID are used.

# true = require POST /api/auth/request-registration-code/ then registration_otp on register.
REGISTER_REQUIRE_EMAIL_OTP=false

# false = server uses DEFAULT_SHIPPING_AMOUNT only (recommended). true = accept client shipping_amount (dev).
CHECKOUT_TRUST_CLIENT_SHIPPING=false
DEFAULT_SHIPPING_AMOUNT=0
